{
  "name": "rustdesk-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright E2E tests for RustDesk Admin Console",
  "scripts": {
    "test": "npx playwright test",
    "test:e2e": "npx playwright test --reporter=html",
    "test:debug": "npx playwright test --debug",
    "test:ui": "npx playwright test --ui",
    "postinstall": "npx playwright install chromium --with-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3"
  }
}
